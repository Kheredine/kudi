# Kudi App - Environment Variables
# Copy this file to .env and fill in your values

# OpenAI key is NO LONGER used client-side.
# Set it as a Supabase Edge Function secret instead:
#   supabase secrets set OPENAI_API_KEY=sk-your-key-here
VITE_OPENAI_API_KEY=

# Supabase (these are safe for client-side — they're designed to be public)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ⛔ NEVER put secret/service-role keys in this file!
# The VITE_ prefix makes them visible in the browser bundle.